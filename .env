# CloseTheOffer — deploy-time config (gitignored; never commit).
# deploy.sh sources this automatically.
#
# SECRETS NOW LIVE IN SSM PARAMETER STORE (SecureString), not here:
#   /closetheoffer/adzuna-app-key       (Adzuna app_key)
#   /closetheoffer/jsearch-rapidapi-key (JSearch RapidAPI key — create when you have one)
# The job-search Lambda fetches them at runtime. Keep secret VALUES out of this file.

# Adzuna app_id is a PUBLIC identifier (safe here). The app_key is in SSM.
export ADZUNA_APP_ID="eb751fdc"
# export ADZUNA_APP_KEY=""        # moved to SSM: /closetheoffer/adzuna-app-key
# export JSEARCH_RAPIDAPI_KEY=""  # moved to SSM: /closetheoffer/jsearch-rapidapi-key

# Google OAuth (optional) — for "Continue with Google" federation.
# Note: the Google client SECRET is stored in Cognito at deploy time, not in a Lambda env.
# export GOOGLE_CLIENT_ID=""
# export GOOGLE_CLIENT_SECRET=""
